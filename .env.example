# Local development defaults to http://localhost:5180 when this value is omitted.
# Production uses the same Vercel domain, so VITE_API_BASE_URL should be omitted.
VITE_API_BASE_URL=http://localhost:5180

# Vercel Functions + Neon (server-only; never prefix these with VITE_).
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
ADMINAUTH__USERNAME=admin
ADMINAUTH__PASSWORD=replace-with-a-strong-password
ADMINAUTH__JWTSIGNINGKEY=replace-with-at-least-32-random-characters
